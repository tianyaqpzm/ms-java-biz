<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dark.aiagent.infrastructure.persistence.prompt.mapper.PromptMapper">

    <select id="findActiveBySlug" resultType="com.dark.aiagent.infrastructure.persistence.prompt.entity.PromptVersionDO">
        SELECT v.* 
        FROM ms_prompt_version v
        JOIN ms_prompt_template t ON v.template_id = t.id
        WHERE t.slug = #{slug} 
          AND v.is_active = TRUE
        LIMIT 1
    </select>

</mapper>
